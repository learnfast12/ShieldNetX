<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#0a0a0f">

    <TextView
        android:text="🛡️"
        android:textSize="80sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:text="Attack Blocked!"
        android:textSize="28sp"
        android:textColor="#FF2D2D"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:text="ShieldNetX stopped a dangerous link"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1a0505"
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/tv_score"
            android:text="--"
            android:textSize="64sp"
            android:textColor="#FF2D2D"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="THREAT SCORE OUT OF 100"
            android:textSize="12sp"
            android:textColor="#888888"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tv_level"
            android:text="CRITICAL"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:background="#FF2D2D"
            android:gravity="center"
            android:padding="8dp"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tv_url"
        android:text="Loading..."
        android:textSize="12sp"
        android:textColor="#FF8888"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btn_safe"
        android:text="← Take Me Back to Safety"
        android:backgroundTint="#0066FF"
        android:layout_width="match_parent"
        android:layout_height="56dp"/>
</LinearLayout>
